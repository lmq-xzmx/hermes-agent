{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes File Manager",
  "version": "1.0.0",
  "identifier": "com.hermes.file-manager",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:8081",
    "beforeBuildCommand": "",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hermes File Manager",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "url": "../web/app.html",
        "label": "main",
        "devtools": true
      },
      {
        "title": "快捷浮窗",
        "width": 360,
        "height": 480,
        "minWidth": 280,
        "minHeight": 360,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "url": "../web/floating.html",
        "label": "floating",
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../web/*"
    ],
    "externalBin": [],
    "copyright": "Copyright 2024 Hermes Agent",
    "category": "Productivity",
    "shortDescription": "File management with knowledge sync",
    "longDescription": "Hermes File Manager provides document storage, space isolation, RBAC permissions, and knowledge synchronization with llm_wiki."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
