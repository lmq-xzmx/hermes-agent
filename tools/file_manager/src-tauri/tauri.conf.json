{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes File Manager",
  "version": "1.0.0",
  "identifier": "com.hermes.file-manager",
  "build": {
    "devUrl": "http://localhost:8080",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8080 https://localhost:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "windows": [
      {
        "title": "Hermes File Manager",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "url": "app.html",
        "label": "main",
        "devtools": true
      },
      {
        "title": "快捷浮窗",
        "width": 360,
        "height": 480,
        "minWidth": 280,
        "minHeight": 360,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "url": "floating.html",
        "label": "floating",
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../web/*"
    ],
    "copyright": "Copyright 2024 Hermes Agent",
    "category": "Productivity"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
